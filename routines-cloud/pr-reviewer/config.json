{
  "name": "Sleepwalker PR Reviewer",
  "tier": "C",
  "triggers": [
    {
      "type": "github",
      "event": "pull_request.opened",
      "filters": {
        "is_draft": false,
        "from_fork": false
      }
    },
    {
      "type": "github",
      "event": "pull_request.synchronize",
      "filters": {
        "is_draft": false
      }
    }
  ],
  "repos": "all-tracked",
  "connectors": ["github"],
  "env_vars": [],
  "recommended_schedule": null,
  "branch_policy": "claude/sleepwalker/pr-reviewer/*",
  "approx_runs_per_week": 20
}
