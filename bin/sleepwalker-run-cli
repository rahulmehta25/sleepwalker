#!/bin/bash
# Sleepwalker CLI supervisor.
# Wraps codex/gemini invocations with v0.1-equivalent safety semantics for
# runtimes that have no hook schema. The only entry point launchd invokes
# for v0.2 Codex/Gemini scheduled jobs.
#
# USAGE (launchd and Run-now both use this form):
#   /abs/path/bin/sleepwalker-run-cli <runtime> <slug> [bundle_dir]
#
# The optional [bundle_dir] third argument is the absolute path to the bundle
# directory (routines-<runtime>/<slug>). Adapters pass it explicitly so the
# supervisor resolves prompt.md + config.json correctly when invoked from a
# staged supervisor copy in ~/.sleepwalker/bin/ (where $(dirname $0)/.. would
# otherwise resolve to ~/.sleepwalker, not the repo). Omitted for backward
# compatibility with direct invocations of bin/sleepwalker-run-cli from inside
# the repo tree — those still work.
#
# INVARIANTS (enforced by this script):
#   - User prompt text NEVER touches argv or a shell-expanded string (Pitfall #4).
#   - stdin-only prompt routing (cat prompt.md | codex exec - --json).
#   - All audit writes pass through perl ANSI strip (SAFE-02).
#   - Budget exceeded -> SIGTERM + budget_exceeded event.
#   - Exactly one `started` event + exactly one terminal event per invocation.
#
# EXIT CODES:
#   0   — any terminal state (completed/failed/deferred/budget_exceeded)
#   64  — EX_USAGE (missing args)
#   66  — EX_NOINPUT (bundle prompt.md missing)
#   127 — CLI binary not found on any PATH source

set -euo pipefail

# --- Inputs ---
RUNTIME="${1:-}"   # "codex" | "gemini"
SLUG="${2:-}"
BUNDLE_ARG="${3:-}"  # Optional absolute bundle path; when empty we derive from $(dirname $0)/..
[ -z "$RUNTIME" ] && { echo "usage: $0 <runtime> <slug> [bundle_dir]" >&2; exit 64; }
[ -z "$SLUG" ]    && { echo "usage: $0 <runtime> <slug> [bundle_dir]" >&2; exit 64; }

# --- Runtime allowlist (MUST run before PATH resolution to prevent shell injection) ---
case "$RUNTIME" in
  codex|gemini) ;;
  *) echo "error: unknown runtime '$RUNTIME' (expected codex or gemini)" >&2; exit 64 ;;
esac

# --- Paths ---
# When bundle_dir is passed as $3 (adapter deploy flow post-staging), use it
# verbatim. Otherwise fall back to the v0.1-era $(dirname $0)/.. derivation so
# direct invocations from inside the repo (developer-run, supervisor-tests.sh
# harness) keep working.
if [ -n "$BUNDLE_ARG" ]; then
  BUNDLE_DIR="$BUNDLE_ARG"
  REPO_ROOT="$(cd "$(dirname "$BUNDLE_DIR")/.." && pwd 2>/dev/null || echo "")"
else
  REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
  BUNDLE_DIR="${REPO_ROOT}/routines-${RUNTIME}/${SLUG}"
fi
PROMPT_FILE="${BUNDLE_DIR}/prompt.md"
CONFIG_FILE="${BUNDLE_DIR}/config.json"
AUDIT_FILE="${HOME}/.sleepwalker/audit.jsonl"
LOCK_FILE="${HOME}/.sleepwalker/audit.jsonl.lock"
SETTINGS_FILE="${HOME}/.sleepwalker/settings.json"
STATE_DIR="${HOME}/.sleepwalker"
FLEET="${RUNTIME}/${SLUG}"

mkdir -p "$STATE_DIR" "${STATE_DIR}/logs"
touch "$AUDIT_FILE"
touch "$LOCK_FILE"

# --- Safety envs (SAFE-02 — re-export defensively; plist already sets these) ---
export NO_COLOR=1
export TERM=dumb
export CI=true

# --- Helper: audit emit (QUEU-04: flock-wrapped to eliminate concurrent-write race) ---
# Per v0.1 CONCERNS.md §concurrent JSONL race + RESEARCH §1.7 live synthetic.
# Uses POSIX flock(1) FD form on ${LOCK_FILE} sidecar with 5s timeout.
# The lock file is a separate sidecar (BashFAQ/045); never locks the data file
# itself. Kernel auto-releases advisory locks on process death — no stale-lock
# cleanup required. Lock path is shared byte-identical with hooks/sleepwalker-
# audit-log.sh (Plan 05-05) so writers across both paths serialize on one mutex.
# Supervisor chooses graceful fallthrough (|| true) on flock timeout/absence:
# the audit line is the supervisor's only record of the run, so we prefer
# reintroducing the narrow v0.1 race for that one entry over dropping the line.
# Size-based rotation of $AUDIT_FILE. Caller MUST hold the flock on
# $LOCK_FILE (via `flock -x 200` in a surrounding subshell) so concurrent
# writers cannot both observe "over cap" and both rotate.
#
# Policy: keep 3 generations (.1 newest, .3 oldest). Cap is
# SLEEPWALKER_AUDIT_MAX_BYTES if set (tests + tuning), else 10 MB —
# which, at ~200 bytes/line average, caps each generation at ~50k events.
#
# Identical logic lives in hooks/sleepwalker-audit-log.sh; both writers
# share the same rotation policy so audit.jsonl behavior is symmetric
# regardless of which writer tripped the threshold. When updating one,
# update the other.
_audit_rotate_if_needed() {
  local max_bytes size
  max_bytes="${SLEEPWALKER_AUDIT_MAX_BYTES:-10485760}"
  [ -f "$AUDIT_FILE" ] || return 0
  size=$(wc -c < "$AUDIT_FILE" 2>/dev/null | tr -d ' ')
  [ "${size:-0}" -gt "$max_bytes" ] || return 0
  # Shift oldest-to-youngest so .1 is always the most recent rotation.
  # `rm -f` + `mv -f` tolerate missing intermediates (common on the first
  # few rotations when .2/.3 don't exist yet).
  [ -f "${AUDIT_FILE}.3" ] && rm -f "${AUDIT_FILE}.3"
  [ -f "${AUDIT_FILE}.2" ] && mv -f "${AUDIT_FILE}.2" "${AUDIT_FILE}.3"
  [ -f "${AUDIT_FILE}.1" ] && mv -f "${AUDIT_FILE}.1" "${AUDIT_FILE}.2"
  mv -f "$AUDIT_FILE" "${AUDIT_FILE}.1"
  touch "$AUDIT_FILE"
}

# $1 = event name; $2 = extra JSON fragment (already-formed key:value pairs, no leading/trailing comma)
audit_emit() {
  local ts event extra
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  event="$1"
  extra="${2:-}"
  if [ -n "$extra" ]; then
    (
      flock -w 5 -e 200 || true
      _audit_rotate_if_needed
      printf '{"ts":"%s","fleet":"%s","runtime":"%s","event":"%s",%s}\n' \
        "$ts" "$FLEET" "$RUNTIME" "$event" "$extra" >> "$AUDIT_FILE"
    ) 200>"$LOCK_FILE"
  else
    (
      flock -w 5 -e 200 || true
      _audit_rotate_if_needed
      printf '{"ts":"%s","fleet":"%s","runtime":"%s","event":"%s"}\n' \
        "$ts" "$FLEET" "$RUNTIME" "$event" >> "$AUDIT_FILE"
    ) 200>"$LOCK_FILE"
  fi
}

# --- Helper: strip ANSI (CSI + OSC + DCS/PM/APC) ---
# Reads from stdin, writes ANSI-stripped content to stdout. perl is macOS built-in at /usr/bin/perl.
strip_ansi() {
  perl -pe 's/\e\[[0-9;?]*[a-zA-Z]//g; s/\e\][^\a]*\a//g; s/\e[PX^_][^\e]*\e\\//g'
}

# --- Preflight: bundle prompt must exist (Pitfall #6) ---
if [ ! -f "$PROMPT_FILE" ]; then
  audit_emit "failed" "\"reason\":\"bundle not found\",\"bundle\":\"${BUNDLE_DIR}\""
  exit 66
fi

# --- PATH resolution (Pitfall #1 — launchd strips PATH) ---
if command -v "$RUNTIME" >/dev/null 2>&1; then
  CLI_ABS="$(command -v "$RUNTIME")"
else
  # Fallback: login-shell PATH via zsh then bash. A background-subshell watchdog
  # (SIGKILL after 10 s) is used rather than alarm()+exec because macOS ARM64
  # login-shell init can reset SIGALRM disposition, making the POSIX exec()
  # timer guarantee unreliable. The watchdog sends SIGKILL from the parent
  # process, bypassing any signal handler the child may have installed.
  for _lsh in /bin/zsh /bin/bash; do
    if [ -z "$CLI_ABS" ] && [ -x "$_lsh" ]; then
      _pt="$(mktemp -t sw-pathresolve.XXXXXX 2>/dev/null)" || true
      if [ -n "$_pt" ]; then
        "$_lsh" -l -c "command -v '$RUNTIME'" > "$_pt" 2>/dev/null &
        _pid=$!
        ( sleep 10 && kill "$_pid" 2>/dev/null ) &
        _wd=$!
        wait "$_pid" 2>/dev/null || true
        kill "$_wd" 2>/dev/null; wait "$_wd" 2>/dev/null || true
        CLI_ABS="$(head -1 "$_pt" 2>/dev/null || true)"
        rm -f "$_pt"
      fi
    fi
  done
  unset _lsh _pt _pid _wd
  if [ -z "$CLI_ABS" ]; then
    audit_emit "failed" "\"reason\":\"$RUNTIME not found on PATH\""
    exit 127
  fi
fi

# --- Sleep window gate ---
HOUR=$(date +%H | sed 's/^0//'); HOUR=${HOUR:-0}
SLEEP_START=$(jq -r '.sleep_window.start_hour // 23' "$SETTINGS_FILE" 2>/dev/null || echo 23)
SLEEP_END=$(jq -r '.sleep_window.end_hour // 7'     "$SETTINGS_FILE" 2>/dev/null || echo 7)
if [ "$SLEEP_START" -gt "$SLEEP_END" ]; then
  if [ "$HOUR" -ge "$SLEEP_START" ] || [ "$HOUR" -lt "$SLEEP_END" ]; then IN_SLEEP=1; else IN_SLEEP=0; fi
else
  if [ "$HOUR" -ge "$SLEEP_START" ] && [ "$HOUR" -lt "$SLEEP_END" ]; then IN_SLEEP=1; else IN_SLEEP=0; fi
fi
if [ "$IN_SLEEP" -eq 0 ] && [ "${SLEEPWALKER_MODE:-auto}" != "overnight" ]; then
  audit_emit "deferred" "\"reason\":\"outside sleep window\",\"hour\":$HOUR"
  exit 0
fi

# --- Reversibility / policy gate ---
REVERSIBILITY=$(jq -r '.reversibility // "yellow"' "$CONFIG_FILE" 2>/dev/null || echo "yellow")
POLICY=$(jq -r --arg f "$FLEET" '.policies[$f] // "balanced"' "$SETTINGS_FILE" 2>/dev/null || echo "balanced")
DECISION="allow"
if [ "$POLICY" = "strict" ]   && [ "$REVERSIBILITY" != "green" ]; then DECISION="defer"; fi
if [ "$POLICY" = "balanced" ] && [ "$REVERSIBILITY" = "red" ];   then DECISION="defer"; fi
if [ "$DECISION" = "defer" ]; then
  audit_emit "deferred" "\"reason\":\"policy $POLICY blocks $REVERSIBILITY\""
  exit 0
fi

# --- Char budget (default 40000 if config is absent or malformed) ---
BUDGET=$(jq -r '.budget // 40000' "$CONFIG_FILE" 2>/dev/null || echo 40000)

# --- Emit started event ---
audit_emit "started" "\"cli\":\"$CLI_ABS\",\"budget\":$BUDGET"

# --- CLI argv dispatch (per-runtime; NO user text in argv ever) ---
case "$RUNTIME" in
  codex)
    # --skip-git-repo-check: the staged bundle ~/.sleepwalker/staged-bundles/<runtime>/<slug>/
    # is not a git repo, so codex's default trusted-directory check would refuse to run.
    # Plan 02-12 put the supervisor's CWD in the staged bundle to escape TCC; this flag
    # tells codex that's expected and safe.
    CLI_ARGS=(exec - --json --skip-git-repo-check)
    ;;
  gemini)
    CLI_ARGS=(-p - --output-format stream-json --yolo)
    ;;
  *)
    audit_emit "failed" "\"reason\":\"unknown runtime $RUNTIME\""
    exit 64
    ;;
esac

# --- Invoke CLI with stdin-piped prompt, stream through ANSI strip + budget watchdog ---
OUTPUT_FILE="$(mktemp -t sleepwalker-run-cli.XXXXXX)"
trap 'rm -f "$OUTPUT_FILE"' EXIT

# stdin comes from prompt.md; stdout+stderr combine -> strip_ansi -> tee to OUTPUT_FILE (discarded from our stdout)
set +e
cat "$PROMPT_FILE" | "$CLI_ABS" "${CLI_ARGS[@]}" 2>&1 | strip_ansi | tee "$OUTPUT_FILE" >/dev/null &
CLI_PID=$!

# Background char-budget watchdog: polls wc -c every second; SIGTERM + SIGKILL-after-2s on exceed
(
  while kill -0 "$CLI_PID" 2>/dev/null; do
    sleep 1
    SIZE=$(wc -c < "$OUTPUT_FILE" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt "$BUDGET" ]; then
      kill -TERM "$CLI_PID" 2>/dev/null || true
      sleep 2
      kill -KILL "$CLI_PID" 2>/dev/null || true
      break
    fi
  done
) &
WATCHDOG_PID=$!

# Redirect stderr around `wait` to suppress bash's pipeline-member-status
# notice. When the watchdog SIGTERMs $CLI_PID (which, as the tail of a
# backgrounded pipeline, is tee(1)), the other pipeline members die with
# mixed signals (codex=SIGPIPE/141, strip_ansi=SIGPIPE/141, cat=Done) and
# bash synthesizes a 4-line status dump to its own stderr — harmless, but
# it lands in ~/.sleepwalker/logs/<label>.err on every budget-exceeded run
# ("Terminated: 15 | tee ..." etc.) and looks alarming. The audit event
# already captures exit code + chars_consumed, so discarding this dump
# loses no diagnostic signal. Redirect via a group (not a subshell) so
# $CLI_EXIT remains assignable from the caller's scope.
{ wait "$CLI_PID"; CLI_EXIT=$?; } 2>/dev/null

# Reap the watchdog silently (kill's ESRCH-if-already-dead + any residual
# job-control notice from the backgrounded subshell both go to /dev/null).
{ kill "$WATCHDOG_PID" 2>/dev/null; wait "$WATCHDOG_PID" 2>/dev/null; } || true
set -e

FINAL_SIZE=$(wc -c < "$OUTPUT_FILE" 2>/dev/null || echo 0)

# --- Emit terminal event (exactly one: completed | failed | budget_exceeded) ---
# JSON-safe preview: `head -c 500 | jq -Rs .` produces a valid JSON string literal
if [ "$FINAL_SIZE" -gt "$BUDGET" ] && [ "$CLI_EXIT" -ne 0 ]; then
  PARTIAL_PREVIEW=$(head -c 500 "$OUTPUT_FILE" | jq -Rs .)
  audit_emit "budget_exceeded" "\"chars_consumed\":$FINAL_SIZE,\"chars_limit\":$BUDGET,\"partial_output_bytes\":$FINAL_SIZE,\"preview\":$PARTIAL_PREVIEW,\"exit_code\":$CLI_EXIT"
  exit 0
fi
if [ "$CLI_EXIT" -eq 0 ]; then
  PREVIEW=$(head -c 500 "$OUTPUT_FILE" | jq -Rs .)
  audit_emit "completed" "\"chars_consumed\":$FINAL_SIZE,\"preview\":$PREVIEW,\"exit_code\":0"
else
  PREVIEW=$(head -c 500 "$OUTPUT_FILE" | jq -Rs .)
  audit_emit "failed" "\"chars_consumed\":$FINAL_SIZE,\"preview\":$PREVIEW,\"exit_code\":$CLI_EXIT"
fi
exit 0
